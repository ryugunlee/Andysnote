modules = ["python-3.11", "nodejs-20"]
[agent]
expertMode = true

[userenv]

[userenv.shared]

[[ports]]
localPort = 8000
externalPort = 80

[nix]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 8000 --bind 0.0.0.0"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"
